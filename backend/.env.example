# -----------------------------------------------------------------------------
# 環境変数サンプル（本番では .env に頼らず環境変数で設定すること）
# -----------------------------------------------------------------------------
# 使い方:
#   1. このファイルをコピー: cp .env.example .env
#   2. .env に実際の値を記入（.env は Git にコミットしない）
# 本番 (Lambda 等):
#   .env は使わず、実行環境の環境変数に DATABASE_URL, MAPTILER_API_KEY を設定する
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# データベース
# -----------------------------------------------------------------------------
# ローカル: docker compose で MySQL を起動した場合の接続URL
# 本番: RDS 等の接続URL を環境変数で設定
DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/signage_dev?charset=utf8mb4

# -----------------------------------------------------------------------------
# MapTiler（住所検証・ジオコーディング）
# -----------------------------------------------------------------------------
# MapTiler Cloud で発行した API キー。未設定時は住所検証をスキップする。
# 本番: Lambda の環境変数などで MAPTILER_API_KEY を設定すること
# https://www.maptiler.com/cloud/
MAPTILER_API_KEY=
