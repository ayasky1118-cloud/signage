# 全環境共通の設定例。.env にコピーして使用。
# 環境別の API 接続先は .env.development / .env.staging / .env.production で管理。

# MapTiler API キー（地図表示用）
# MapTiler Cloud で発行: https://www.maptiler.com/cloud/
# 未設定時は地図が表示されず「VITE_MAPTILER_API_KEY を設定してください」と表示
VITE_MAPTILER_API_KEY=oB8ILFlAMMLB99O7Iqaa

# AWS Cognito（認証用）
# CGS 環境用: AWS コンソールで User Pool を新規作成し、ID を設定（06b.Cognito作成手順.md 参照）
# 未設定時は従来のテスト環境（sinage_old）の User Pool にフォールバック
VITE_COGNITO_USER_POOL_ID=ap-northeast-1_xxxxxxxxx
VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
